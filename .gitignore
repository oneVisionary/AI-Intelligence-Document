```gitignore
# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class
*.pyc

# =========================
# Virtual Environments
# =========================
venv/
.venv/
env/

# =========================
# Environment Variables
# =========================
.env
.env.*
!.env.example

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# Uploads
# =========================
uploads/

# =========================
# Database Files
# =========================
*.db
*.sqlite3

# =========================
# IDE / Editors
# =========================
.vscode/
.idea/

# =========================
# Testing
# =========================
.pytest_cache/
.coverage
htmlcov/

# =========================
# Build Artifacts
# =========================
build/
dist/
*.egg-info/

# =========================
# OS Files
# =========================
.DS_Store
Thumbs.db

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# Docker
# =========================
.docker/

# =========================
# Hugging Face Cache
# =========================
.cache/
huggingface/

# =========================
# Ollama
# =========================
ollama-models/

# =========================
# Alembic Cache
# =========================
backend/alembic/__pycache__/
backend/alembic/versions/__pycache__/
backend/alembic/
backend/alembic.ini
# =========================
# Misc
# =========================
*.swp
*.swo
```
